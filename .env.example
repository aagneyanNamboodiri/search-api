# Elasticsearch
# Docker (default) — container "elasticsearch" exposes 9200 on localhost
SEARCH_API_ES_URL=http://localhost:9200
# If ES has security enabled (default for ES 8+), use:
# SEARCH_API_ES_URL=https://localhost:9200
# and set these:
# SEARCH_API_ES_USERNAME=elastic
# SEARCH_API_ES_PASSWORD=changeme
# SEARCH_API_ES_VERIFY_CERTS=false

# PostgreSQL (local)
SEARCH_API_PG_HOST=localhost
SEARCH_API_PG_PORT=5432
SEARCH_API_PG_DATABASE=infiviz
SEARCH_API_PG_USER=postgres
SEARCH_API_PG_PASSWORD=postgres
